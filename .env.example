# Ethereum RPC (required for V1 vaults, V2 fee reads, Turtle Club on-chain reads)
ETH_RPC_URL=https://eth.llamarpc.com

# Per-chain RPCs — used by fetch-v2-fees.ts and fetch-curation.ts (Turtle Club)
# Format: RPC_URI_FOR_{chainId}
RPC_URI_FOR_1=https://eth.llamarpc.com
RPC_URI_FOR_10=https://optimism.llamarpc.com
RPC_URI_FOR_100=https://rpc.gnosischain.com
RPC_URI_FOR_137=https://polygon.llamarpc.com
RPC_URI_FOR_250=https://rpc.ftm.tools
RPC_URI_FOR_8453=https://base.llamarpc.com
RPC_URI_FOR_42161=https://arbitrum.llamarpc.com
RPC_URI_FOR_747474=https://rpc.katana.yearn.fi
RPC_URI_FOR_999=https://rpc.countzero.xyz/evm
