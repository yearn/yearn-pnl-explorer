{
  "name": "yearn-tvl",
  "private": true,
  "workspaces": ["packages/*", "scripts"],
  "scripts": {
    "dev:api": "bun run --watch packages/api/src/index.ts",
    "dev:dashboard": "bun run --cwd packages/dashboard vite",
    "seed": "bun run scripts/seed.ts",
    "seed:extra": "bun run fetch:reports && bun run scripts/fetch-v2-fees.ts && bun run fetch:prices && bun run scripts/reprice-reports.ts",
    "fetch:kong": "bun run scripts/fetch-kong.ts",
    "fetch:defillama": "bun run scripts/fetch-defillama.ts",
    "fetch:curation": "bun run scripts/fetch-curation.ts",
    "fetch:reports": "bun run scripts/fetch-reports.ts",
    "fetch:v1": "bun run scripts/fetch-v1-vaults.ts",
    "fetch:depositors": "bun run scripts/fetch-depositors.ts",
    "fetch:prices": "bun run scripts/fetch-historical-prices.ts",
    "refresh:retired": "bun run scripts/refresh-retired.ts",
    "report": "bun run scripts/generate-report.ts",
    "audit": "bun run ./scripts/audit.ts",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run packages/db/src/migrate.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/dashboard/tsconfig.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pdfkit": "^0.17.5",
    "pdfkit": "^0.17.2",
    "typescript": "^5.9.3"
  }
}
